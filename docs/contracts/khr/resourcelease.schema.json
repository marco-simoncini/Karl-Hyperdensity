{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karl.local/schemas/khr/resourcelease.schema.json",
  "title": "KHR ResourceLease",
  "description": "Unified ResourceLease contract (ADR-0005, Sprint KHR-B). CRD-aligned; controllers not active.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "hyperdensity.karl.io/v1alpha1"
    },
    "kind": {
      "type": "string",
      "const": "ResourceLease"
    },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": { "$ref": "#/$defs/spec" },
    "status": { "$ref": "#/$defs/status" }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": ["leaseKind", "shell", "cell", "provider"],
      "properties": {
        "leaseKind": { "$ref": "#/$defs/leaseKind" },
        "shell": { "$ref": "#/$defs/shell" },
        "cell": { "$ref": "#/$defs/cell" },
        "provider": { "$ref": "#/$defs/provider" },
        "resources": { "$ref": "#/$defs/resources" },
        "storage": { "$ref": "#/$defs/storage" },
        "network": { "$ref": "#/$defs/network" },
        "policy": { "type": "object" },
        "transfer": { "$ref": "#/$defs/transfer" },
        "governance": { "$ref": "#/$defs/governance" },
        "evidence": { "type": "object" },
        "rollback": { "type": "object" },
        "expiration": { "type": "object" },
        "promotion": { "type": "object" }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "leaseKind": { "const": "runtime" } } },
          "then": {
            "required": ["resources", "storage", "network", "policy"]
          }
        },
        {
          "if": { "properties": { "leaseKind": { "const": "transfer" } } },
          "then": { "required": ["transfer"] }
        }
      ]
    },
    "leaseKind": {
      "type": "string",
      "enum": ["runtime", "transfer"]
    },
    "shell": {
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "ref": { "type": "string" },
        "experience": { "type": "string" }
      },
      "additionalProperties": true
    },
    "cell": {
      "type": "object",
      "properties": {
        "ref": { "type": "string" },
        "hostSelector": { "type": "object" },
        "runtimeClass": { "type": "string" }
      },
      "additionalProperties": true
    },
    "provider": {
      "type": "string",
      "enum": [
        "khr.native",
        "kubevirt.compatibility",
        "kubevirt.public-cloud-fallback",
        "khr.native.ovn",
        "kubevirt.legacy.ovn",
        "kubernetes.cni",
        "cloud.vpc.aws",
        "cloud.vnet.azure",
        "cloud.vpc.gcp",
        "baremetal.bridge",
        "baremetal.vlan"
      ]
    },
    "transfer": {
      "type": "object",
      "required": ["donor", "receiver", "resource", "mode"],
      "properties": {
        "donor": { "$ref": "#/$defs/leasePartyRef" },
        "receiver": { "$ref": "#/$defs/leasePartyRef" },
        "resource": {
          "type": "string",
          "enum": ["cpu", "memory", "disk", "network", "gpu"]
        },
        "amount": { "type": "object" },
        "mode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "leasePartyRef": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "apiGroup": { "type": "string" },
        "kind": { "type": "string", "enum": ["Shell", "Cell"] },
        "namespace": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "properties": {
        "dryRunOnly": { "type": "boolean" },
        "rollbackPlanRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "namespace": { "type": "string" }
          },
          "additionalProperties": true
        },
        "rollbackRequired": { "type": "boolean" },
        "verificationHooks": { "type": "object" },
        "noRestart": { "type": "boolean" },
        "guestVisible": { "type": "boolean" },
        "telemetryConvergedRequired": { "type": "boolean" },
        "durationSeconds": { "type": "integer", "minimum": 0 },
        "ttlSeconds": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu": { "$ref": "#/$defs/resourceQuantity" },
        "memory": { "$ref": "#/$defs/resourceQuantity" }
      },
      "additionalProperties": true
    },
    "resourceQuantity": {
      "type": "object",
      "properties": {
        "request": { "type": "string" },
        "limit": { "type": "string" }
      },
      "additionalProperties": true
    },
    "storage": {
      "type": "object",
      "properties": {
        "disks": {
          "type": "array",
          "items": { "$ref": "#/$defs/disk" }
        },
        "defaultDiscardPolicy": { "$ref": "#/$defs/discardPolicy" },
        "promoteToImage": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "goldenRef": { "type": "string" },
            "policy": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "disk": {
      "type": "object",
      "required": ["name", "role", "mode", "source"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "mode": { "$ref": "#/$defs/diskMode" },
        "source": { "$ref": "#/$defs/diskSource" },
        "sourceRef": { "type": "string" },
        "size": { "type": "string" },
        "readonly": { "type": "boolean" },
        "discardPolicy": { "$ref": "#/$defs/discardPolicy" },
        "mountIntent": { "type": "string" },
        "promotePolicy": { "type": "string" },
        "scope": { "type": "string" }
      },
      "additionalProperties": true
    },
    "diskMode": {
      "type": "string",
      "enum": ["ephemeralOverlay", "ephemeralClone", "scratch", "readonly", "persistent"]
    },
    "diskSource": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "$ref": "#/$defs/sourceType" },
        "ref": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sourceType": {
      "type": "string",
      "enum": ["pvc", "image", "snapshot", "volume", "goldenImage"]
    },
    "discardPolicy": {
      "type": "string",
      "enum": ["deleteOnStop", "keepOnFailure", "promoteOnRequest"]
    },
    "network": {
      "type": "object",
      "properties": {
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/networkAttachment" }
        },
        "policies": { "type": "array", "items": { "type": "object" } },
        "exposure": { "$ref": "#/$defs/exposure" },
        "providerNetwork": { "$ref": "#/$defs/providerNetwork" },
        "networkLease": { "type": "object" }
      },
      "additionalProperties": true
    },
    "networkAttachment": {
      "type": "object",
      "required": ["name", "networkRef", "role"],
      "properties": {
        "name": { "type": "string" },
        "networkRef": { "type": "string" },
        "role": { "type": "string" },
        "ipam": { "type": "string" },
        "macPolicy": { "type": "string" },
        "isolation": { "type": "string" },
        "providerBinding": { "type": "string" }
      },
      "additionalProperties": true
    },
    "exposure": {
      "type": "object",
      "properties": {
        "ingress": { "type": "string" },
        "egress": { "type": "string" },
        "directPublic": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "providerNetwork": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "domainRef": { "type": "string" }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "properties": {
        "phase": { "$ref": "#/$defs/phase" },
        "providerBinding": { "type": "object" },
        "effectiveResources": { "type": "object" },
        "conditions": { "type": "array" },
        "observedAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "phase": {
      "type": "string",
      "enum": [
        "Pending",
        "DryRunValidated",
        "Bound",
        "Active",
        "Completing",
        "Completed",
        "Failed",
        "RolledBack"
      ]
    }
  }
}
