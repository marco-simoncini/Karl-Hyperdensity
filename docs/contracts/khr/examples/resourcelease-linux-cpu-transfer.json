{
  "apiVersion": "hyperdensity.karl.io/v1alpha1",
  "kind": "ResourceLease",
  "metadata": {
    "name": "linux-cpu-envelope-transfer",
    "namespace": "karl-sandbox",
    "annotations": {
      "karl.io/schema-only": "true",
      "karl.io/sprint": "khr-b"
    }
  },
  "spec": {
    "leaseKind": "transfer",
    "shell": {
      "ref": "shell/lease-demo-donor"
    },
    "cell": {
      "ref": "cell/lease-demo-donor-cell"
    },
    "provider": "khr.native",
    "resources": {},
    "storage": {},
    "network": {},
    "policy": {},
    "transfer": {
      "donor": {
        "apiGroup": "runtime.karl.io",
        "kind": "Cell",
        "namespace": "karl-sandbox",
        "name": "lease-demo-donor-cell"
      },
      "receiver": {
        "apiGroup": "runtime.karl.io",
        "kind": "Cell",
        "namespace": "karl-sandbox",
        "name": "lease-demo-receiver-cell"
      },
      "resource": "cpu",
      "amount": {
        "milliCpu": 2000
      },
      "mode": "envelope"
    },
    "governance": {
      "durationSeconds": 120,
      "rollbackPlanRef": {
        "name": "demo-rollback-plan",
        "namespace": "karl-sandbox"
      },
      "rollbackRequired": true,
      "dryRunOnly": true,
      "telemetryConvergedRequired": true
    }
  },
  "status": {
    "phase": "DryRunValidated"
  }
}
