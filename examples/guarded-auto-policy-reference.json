  "requireOperatorFallback": true,
  "requireAudit": true,
  "allowWindowsEvidenceGatedAuto": false,
  "allowSyntheticProductionProof": false,
  "autoApplyExecutionEnabled": false,
  "productionAutonomousApplyAllowed": false,
  "productionScope": false,
  "evidenceRefs": ["hyperdensity_guarded_auto_policy_evidence_v1"],
