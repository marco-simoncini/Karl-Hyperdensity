{
  "apiVersion": "hyperdensity.karl.io/v1alpha1",
  "kind": "ResourceLease",
  "metadata": {
    "name": "windows-memory-dryrun-blocked",
    "namespace": "khr-windows-observation",
    "labels": {
      "khr.karl.io/lane": "windows",
      "khr.karl.io/observation-only": "true"
    },
    "annotations": {
