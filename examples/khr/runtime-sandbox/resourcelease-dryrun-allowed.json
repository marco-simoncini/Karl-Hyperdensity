{
  "apiVersion": "hyperdensity.karl.io/v1alpha1",
  "kind": "ResourceLease",
  "metadata": {
    "name": "khr-runtime-sandbox-lease-allowed",
    "namespace": "khr-runtime-sandbox",
    "labels": {
      "khr.karl.io/sandbox": "true"
    },
    "annotations": {
      "khr.karl.io/resource-port-ref": "cluster/ResourcePort/khr-runtime-sandbox-demo-port"
    }
  },
  "spec": {
    "leaseKind": "transfer",
    "transfer": {
      "donor": {
        "apiGroup": "runtime.karl.io",
        "kind": "Cell",
        "namespace": "khr-runtime-sandbox",
        "name": "demo"
      },
      "receiver": {
        "apiGroup": "runtime.karl.io",
        "kind": "Cell",
        "namespace": "khr-runtime-sandbox",
        "name": "demo-receiver"
      },
      "resource": "cpu",
      "mode": "envelope",
      "amount": { "milliCpu": 250 }
    },
    "governance": {
      "dryRunOnly": true,
      "rollbackPlanRef": {
        "name": "khr-sandbox-rollback",
        "namespace": "khr-runtime-sandbox"
      }
    }
  }
}
