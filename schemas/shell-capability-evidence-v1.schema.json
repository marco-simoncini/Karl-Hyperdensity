{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/shell-capability-evidence-v1.schema.json",
  "title": "KARL Hyperdensity Shell Capability Evidence v1",
  "type": "object",
  "required": [
    "evidenceId",
    "shellId",
    "source",
    "actuator",
    "targetRef",
    "runtimeLayer",
    "cpuEntitlementObserved",
    "memoryEnvelopeObserved",
    "guestEvidenceObserved",
    "qgaObserved",
    "cgroupObserved",
    "libvirtObserved",
    "identityPreserved",
    "rebootRequired",
    "recreateRequired",
    "migrationRequired",
    "runtimeMutationSupportedFamilies",
    "unsupportedFamilies",
    "blockers",
    "evidenceRefs",
    "observedAt"
  ],
  "properties": {
    "evidenceId": { "type": "string" },
    "shellId": { "type": "string" },
    "source": { "const": "FluidVirt" },
    "actuator": { "const": "FluidVirt" },
    "targetRef": { "type": "string" },
    "runtimeLayer": { "type": "string" },
    "cpuEntitlementObserved": { "type": "boolean" },
    "memoryEnvelopeObserved": { "type": "boolean" },
    "guestEvidenceObserved": { "type": "boolean" },
    "qgaObserved": { "type": "boolean" },
    "cgroupObserved": { "type": "boolean" },
    "libvirtObserved": { "type": "boolean" },
    "identityPreserved": { "type": "boolean" },
    "rebootRequired": { "const": false },
    "recreateRequired": { "const": false },
    "migrationRequired": { "const": false },
    "runtimeMutationSupportedFamilies": { "type": "array", "items": { "type": "string" } },
    "unsupportedFamilies": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "observedAt": { "type": "string" }
  }
}
