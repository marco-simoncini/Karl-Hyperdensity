{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/guarded-auto-sandbox-v1.schema.json",
  "title": "KARL Hyperdensity Guarded Auto Sandbox v1",
  "type": "object",
  "required": [
    "guardedAutoSandboxId",
    "guardedAutoSandboxVersion",
    "releaseTrack",
    "sandboxMode",
    "sandboxState",
    "allowedNamespace",
    "productionMutationAllowed",
    "enforcementMode",
    "autonomousProductionApplyAllowed",
    "sandboxAutonomousApplyAllowed",
    "operatorKillSwitchRequired",
    "operatorKillSwitchState",
    "actionSlateId",
    "policyPackId",
    "supportMatrixId",
    "evidenceBundleId",
    "liveResourceAuthorityId",
    "maxActionsPerHour",
    "maxConcurrentActions",
    "maxCpuMove",
    "maxMemoryMove",
    "dryRunRequired",
    "rollbackRequired",
    "auditRequired",
    "verificationRequired",
    "eligibleActionCount",
    "executableActionCount",
    "blockedActionCount",
    "candidateActions",
    "safetyGates",
    "blastRadiusBudget",
    "auditTrail",
    "blockers",
    "limitations",
    "claimBoundaries"
  ],
  "properties": {
    "guardedAutoSandboxId": { "const": "hyperdensity_guarded_auto_sandbox_v1" },
    "guardedAutoSandboxVersion": { "const": "v1" },
    "releaseTrack": { "const": "technical_preview" },
    "sandboxMode": { "const": "guarded_auto_evidence_namespace_only" },
    "sandboxState": {
      "enum": [
        "guarded_auto_sandbox_ready",
        "guarded_auto_sandbox_readiness_only",
        "guarded_auto_sandbox_blocked",
        "guarded_auto_sandbox_unavailable"
      ]
    },
    "allowedNamespace": { "const": "karl-hyperdensity-evidence" },
    "productionMutationAllowed": { "const": false },
    "enforcementMode": { "const": "disabled" },
    "autonomousProductionApplyAllowed": { "const": false },
    "operatorKillSwitchRequired": { "const": true },
    "dryRunRequired": { "const": true },
    "rollbackRequired": { "const": true },
    "auditRequired": { "const": true },
    "verificationRequired": { "const": true },
    "candidateActions": { "type": "array", "items": { "type": "object" } },
    "safetyGates": { "type": "array", "minItems": 10, "items": { "type": "object" } },
    "claimBoundaries": { "type": "array", "minItems": 10, "items": { "type": "string" } }
  },
  "additionalProperties": true
}
