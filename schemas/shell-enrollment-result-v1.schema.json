{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/shell-enrollment-result-v1.schema.json",
  "title": "KARL Hyperdensity Shell Enrollment Result v1",
  "type": "object",
  "required": [
    "enrollmentId",
    "shellId",
    "targetRef",
    "shellKind",
    "enrollmentStatus",
    "identityVerified",
    "capabilityEvidenceLoaded",
    "claimBoundaryAssigned",
    "supportProfileAssigned",
    "eligibleAsDonor",
    "eligibleAsReceiver",
    "protected",
    "blocked",
    "remediable",
    "blockers",
    "remediations",
    "evidenceRefs",
    "productionMutationAllowed",
    "autoApplyAllowed"
  ],
  "properties": {
    "enrollmentId": { "type": "string" },
    "shellId": { "type": "string" },
    "targetRef": { "type": "string" },
    "shellKind": { "type": "string" },
    "enrollmentStatus": { "enum": ["enrolled", "blocked", "remediable", "protected", "rejected"] },
    "identityVerified": { "type": "boolean" },
    "capabilityEvidenceLoaded": { "type": "boolean" },
    "claimBoundaryAssigned": { "type": "boolean" },
    "supportProfileAssigned": { "type": "boolean" },
    "eligibleAsDonor": { "type": "boolean" },
    "eligibleAsReceiver": { "type": "boolean" },
    "protected": { "type": "boolean" },
    "blocked": { "type": "boolean" },
    "remediable": { "type": "boolean" },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "remediations": { "type": "array", "items": { "type": "string" } },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "productionMutationAllowed": { "const": false },
    "autoApplyAllowed": { "const": false }
  }
}
