{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/resource-lease-v1.schema.json",
  "title": "KARL Hyperdensity Resource Lease v1",
  "type": "object",
  "required": [
    "leaseId",
    "donorShellId",
    "receiverShellId",
    "resource",
    "amount",
    "durationSeconds",
    "validFrom",
    "expiresAt",
    "state",
    "dryRunState",
    "rollbackState",
    "risk",
    "approvalMode",
    "autoApplyAllowed",
    "productionMutationAllowed",
    "evidenceRefs",
    "accountingRef",
    "claimBoundary"
  ],
  "properties": {
    "leaseId": { "type": "string" },
    "donorShellId": { "type": "string" },
    "receiverShellId": { "type": "string" },
    "resource": { "enum": ["cpu", "memory", "mixed"] },
    "amount": { "type": "string" },
    "durationSeconds": { "type": "integer", "minimum": 1 },
    "validFrom": { "type": "string" },
    "expiresAt": { "type": "string" },
    "state": { "enum": ["draft", "dry_run", "blocked", "expired", "active", "rolled_back"] },
    "dryRunState": { "type": "string" },
    "rollbackState": { "type": "string" },
    "risk": { "enum": ["low", "medium", "high", "unknown"] },
    "approvalMode": { "const": "operator_required" },
    "autoApplyAllowed": { "const": false },
    "productionMutationAllowed": { "const": false },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "accountingRef": { "type": "string" },
    "claimBoundary": { "type": "array", "items": { "type": "string" } }
  }
}
