{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/runtime-mutation-result-v1.schema.json",
  "title": "KARL Hyperdensity Runtime Mutation Result v1",
  "type": "object",
  "required": [
    "mutationId",
    "movementId",
    "leaseId",
    "targetShellId",
    "actuator",
    "actuatorVersion",
    "resource",
    "direction",
    "requestedAmount",
    "appliedAmount",
    "runtimeObserved",
    "guestObserved",
    "cgroupObserved",
    "libvirtObserved",
    "qgaObserved",
    "identityPreserved",
    "rebootUsed",
    "recreateUsed",
    "rolloutUsed",
    "migrationUsed",
    "rollbackReady",
    "rollbackExecuted",
    "rollbackPassed",
    "sloGuardPassed",
    "donorHealthPreserved",
    "safetyPreserved",
    "evidenceRefs",
    "claimBoundary"
  ],
  "properties": {
    "mutationId": { "type": "string" },
    "movementId": { "type": "string" },
    "leaseId": { "type": "string" },
    "targetShellId": { "type": "string" },
    "actuator": { "const": "FluidVirt" },
    "actuatorVersion": { "type": "string" },
    "resource": { "enum": ["cpu", "memory", "mixed"] },
    "direction": { "enum": ["up", "down", "transfer"] },
    "requestedAmount": { "type": "string" },
    "appliedAmount": { "type": "string" },
    "runtimeObserved": { "type": "boolean" },
    "guestObserved": { "type": "boolean" },
    "cgroupObserved": { "type": "boolean" },
    "libvirtObserved": { "type": "boolean" },
    "qgaObserved": { "type": "boolean" },
    "identityPreserved": { "type": "boolean" },
    "rebootUsed": { "const": false },
    "recreateUsed": { "const": false },
    "rolloutUsed": { "const": false },
    "migrationUsed": { "const": false },
    "rollbackReady": { "type": "boolean" },
    "rollbackExecuted": { "type": "boolean" },
    "rollbackPassed": { "type": "boolean" },
    "sloGuardPassed": { "type": "boolean" },
    "donorHealthPreserved": { "type": "boolean" },
    "safetyPreserved": { "type": "boolean" },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "claimBoundary": { "type": "array", "items": { "type": "string" } }
  }
}
