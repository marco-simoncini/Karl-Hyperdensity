{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/live-resource-authority-v1.schema.json",
  "title": "KARL Live Resource Authority v1",
  "type": "object",
  "required": [
    "authorityId",
    "authorityName",
    "authorityVersion",
    "authorityMode",
    "authorityState",
    "releaseTrack",
    "operationMode",
    "autonomousApplyAllowed",
    "enforcementMode",
    "productionMutationAllowed",
    "evidenceScope",
    "supportMatrixId",
    "evidenceBundleId",
    "policyPackId",
    "profilePackId",
    "uniformContract",
    "runtimeDrivers",
    "liveResourceIntents",
    "runtimeLeases",
    "capabilityChecks",
    "preflightChecks",
    "dryRunSemantics",
    "applySemantics",
    "verificationSemantics",
    "rollbackSemantics",
    "reconciliationSemantics",
    "safetyGates",
    "supportBoundaries",
    "limitations",
    "outOfScope",
    "summary",
    "nextAuthorityAction",
    "authorityBlocker"
  ],
  "properties": {
    "authorityId": { "const": "hyperdensity_live_resource_authority_v1" },
    "authorityName": { "const": "KARL Live Resource Authority" },
    "authorityVersion": { "const": "v1" },
    "authorityMode": { "const": "unified_runtime_control_surface" },
    "releaseTrack": { "const": "technical_preview" },
    "operationMode": { "const": "operator_controlled_projection" },
    "autonomousApplyAllowed": { "const": false },
    "enforcementMode": { "const": "disabled" },
    "productionMutationAllowed": { "const": false },
    "evidenceScope": { "const": "evidence_namespace_only" },
    "supportMatrixId": { "const": "hyperdensity_release_support_matrix_v1" },
    "evidenceBundleId": { "const": "hyperdensity_evidence_bundle_demo_scenario_pack_v1" },
    "policyPackId": { "const": "hyperdensity_policy_pack_v1" },
    "profilePackId": { "const": "hyperdensity_shell_claim_templates_profile_pack_v1" },
    "uniformContract": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "runtimeDrivers": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "liveResourceIntents": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "runtimeLeases": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "capabilityChecks": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "preflightChecks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "dryRunSemantics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "applySemantics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "verificationSemantics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rollbackSemantics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "reconciliationSemantics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "safetyGates": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "supportBoundaries": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "limitations": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "outOfScope": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "summary": { "type": "string" },
    "nextAuthorityAction": { "type": "string" },
    "authorityBlocker": { "type": "string" }
  },
  "additionalProperties": true
}
