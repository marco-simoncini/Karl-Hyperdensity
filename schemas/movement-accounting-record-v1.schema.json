{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/movement-accounting-record-v1.schema.json",
  "title": "KARL Hyperdensity Movement Accounting Record v1",
  "type": "object",
  "required": ["movementAccountingId", "movementId", "actionId", "leaseCandidateId", "applyGateId", "donorShellId", "receiverShellId", "tenant", "resource", "amount", "unit", "durationSeconds", "unitPrice", "unitPriceCurrency", "priceBasis", "grossValue", "controlPlaneCost", "rollbackCost", "riskAdjustment", "netRealizedValue", "sloPreserved", "donorHealthPreserved", "rollbackReady", "rollbackExecuted", "confidence", "claimClassification", "guaranteeEligibleForFuture", "excludedFromGuarantee", "synthetic", "productionScope", "evidenceRefs", "claimBoundary"],
  "properties": {
    "movementAccountingId": { "type": "string" },
    "movementId": { "type": "string" },
    "actionId": { "type": "string" },
    "leaseCandidateId": { "type": "string" },
    "applyGateId": { "type": "string" },
    "donorShellId": { "type": "string" },
    "receiverShellId": { "type": "string" },
    "tenant": { "type": "string" },
    "app": { "type": "string" },
    "resource": { "type": "string" },
    "amount": { "type": "string" },
    "unit": { "type": "string" },
    "durationSeconds": { "type": "integer", "minimum": 0 },
    "unitPriceRef": { "type": "string" },
    "unitPrice": { "type": "number" },
    "unitPriceCurrency": { "type": "string" },
    "priceBasis": { "type": "string" },
    "grossValue": { "type": "number" },
    "controlPlaneCost": { "type": "number" },
    "rollbackCost": { "type": "number" },
    "riskAdjustment": { "type": "number" },
    "netRealizedValue": { "type": "number" },
    "sloPreserved": { "type": "boolean" },
    "donorHealthPreserved": { "type": "boolean" },
    "rollbackReady": { "type": "boolean" },
    "rollbackExecuted": { "type": "boolean" },
    "claimClassification": { "type": "string" },
    "guaranteeEligibleForFuture": { "type": "boolean" },
    "excludedFromGuarantee": { "type": "boolean" },
    "exclusionReason": { "type": "string" },
    "synthetic": { "type": "boolean" },
    "productionScope": { "type": "boolean" },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "claimBoundary": { "type": "array", "items": { "type": "string" } }
