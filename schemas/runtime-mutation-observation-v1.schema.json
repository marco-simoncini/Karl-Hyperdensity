{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/runtime-mutation-observation-v1.schema.json",
  "title": "KARL Hyperdensity Runtime Mutation Observation v1",
  "type": "object",
  "required": ["mutationObservationId", "mutationId", "applyRequestId", "invocationId", "donorShellId", "receiverShellId", "resource", "requestedAmount", "appliedAmount", "identityPreserved", "rebootUsed", "recreateUsed", "rolloutUsed", "migrationUsed", "mutationMatchesPlan", "observedAt", "evidenceRefs", "claimBoundary"],
  "properties": {
    "mutationObservationId": { "type": "string" },
    "mutationId": { "type": "string" },
    "applyRequestId": { "type": "string" },
    "invocationId": { "type": "string" },
    "donorShellId": { "type": "string" },
    "receiverShellId": { "type": "string" },
    "resource": { "type": "string" },
    "requestedAmount": { "type": "string" },
    "appliedAmount": { "type": "string" },
    "donorRuntimeObserved": { "type": "object" },
    "receiverRuntimeObserved": { "type": "object" },
    "donorGuestObserved": { "type": "object" },
    "receiverGuestObserved": { "type": "object" },
    "cgroupObserved": { "type": "boolean" },
    "libvirtObserved": { "type": "boolean" },
    "qgaObserved": { "type": "boolean" },
    "identityPreserved": { "const": true },
    "rebootUsed": { "const": false },
    "recreateUsed": { "const": false },
    "rolloutUsed": { "const": false },
    "migrationUsed": { "const": false },
    "mutationMatchesPlan": { "type": "boolean" },
    "observedAt": { "type": "string" },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "claimBoundary": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } }
  }
}
