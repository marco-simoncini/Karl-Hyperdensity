  "title": "KARL Hyperdensity Auto FluidVirt Invocation v1",
  "type": "object",
  "required": ["invocationId", "actuator", "invocationMode", "productionScope", "productionAutonomousApplyAllowed", "rawRuntimeControlsExposed", "claimBoundary"],
