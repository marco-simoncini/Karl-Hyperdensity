{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/certified-performance-uplift-v1.schema.json",
  "title": "KARL Hyperdensity Certified Performance Uplift v1",
  "type": "object",
  "required": ["upliftId", "actionId", "shellId", "workloadId", "resource", "metric", "beforeValue", "afterValue", "improvementPercent", "confidence", "certified", "certificationScope", "excludedFromUniversalClaim", "evidenceRefs", "claimBoundary"],
  "properties": {
    "upliftId": { "type": "string" },
    "actionId": { "type": "string" },
    "certified": { "type": "boolean" },
    "excludedFromUniversalClaim": { "const": true },
    "confidence": { "type": "number", "minimum": 0 },
    "evidenceRefs": { "type": "array" },
    "claimBoundary": { "type": "array" }
  }
}
