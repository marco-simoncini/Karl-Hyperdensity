{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/hyperdensity-claim-policy-v2.schema.json",
  "title": "KARL Hyperdensity Claim Policy v2",
  "type": "object",
  "required": [
    "claimPolicyId",
    "claimPolicyVersion",
    "estimatedValueAllowed",
    "guaranteedSavingsAllowed",
    "universalPerformanceImprovementAllowed",
    "universalSloProtectionAllowed",
    "certifiedPerformanceUpliftAllowed",
    "logicalVcpuHotplugClaimAllowed",
    "windowsTotalRamHotplugClaimAllowed",
    "ramAboveOriginalClaimAllowed",
    "productionAutonomousApplyAllowed",
    "syntheticFleetProductionClaimAllowed",
    "requiredEvidenceForSavingsGuarantee",
    "requiredEvidenceForPerformanceUplift",
    "forbiddenPhrases",
    "allowedPhrases",
    "conditionalPhrases"
  ],
  "properties": {
    "claimPolicyId": { "const": "hyperdensity_claim_policy_v2" },
    "claimPolicyVersion": { "const": "v2" },
    "estimatedValueAllowed": { "type": "boolean" },
    "guaranteedSavingsAllowed": { "const": false },
    "universalPerformanceImprovementAllowed": { "const": false },
    "universalSloProtectionAllowed": { "type": "boolean" },
    "certifiedPerformanceUpliftAllowed": { "type": "boolean" },
    "logicalVcpuHotplugClaimAllowed": { "const": false },
    "windowsTotalRamHotplugClaimAllowed": { "const": false },
    "ramAboveOriginalClaimAllowed": { "const": false },
    "productionAutonomousApplyAllowed": { "const": false },
    "syntheticFleetProductionClaimAllowed": { "const": false },
    "requiredEvidenceForSavingsGuarantee": { "type": "array", "items": { "type": "string" } },
    "requiredEvidenceForPerformanceUplift": { "type": "array", "items": { "type": "string" } },
    "forbiddenPhrases": { "type": "array", "items": { "type": "string" } },
    "allowedPhrases": { "type": "array", "items": { "type": "string" } },
    "conditionalPhrases": { "type": "array", "items": { "type": "string" } }
  }
}
