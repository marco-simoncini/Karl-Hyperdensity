{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/shell-passport-v1.schema.json",
  "title": "KARL Hyperdensity Shell Passport v1",
  "type": "object",
  "required": [
    "shellId",
    "shellKind",
    "runtimeLayer",
    "tenant",
    "namespace",
    "targetRef",
    "identityStable",
    "supportProfile",
    "cpuEntitlement",
    "memoryEnvelope",
    "donorEligibility",
    "receiverEligibility",
    "rollbackReadiness",
    "sloProfile",
    "evidenceRefs",
    "claimBoundary",
    "blockers",
    "remediations"
  ],
  "properties": {
    "shellId": { "type": "string", "minLength": 1 },
    "shellKind": { "enum": ["linux_container", "linux_vm", "windows_vm", "windows_pool_replica"] },
    "runtimeLayer": { "type": "string" },
    "tenant": { "type": "string" },
    "namespace": { "type": "string" },
    "targetRef": { "type": "string" },
    "identityStable": { "type": "boolean" },
    "supportProfile": { "type": "string" },
    "cpuEntitlement": { "type": "object" },
    "memoryEnvelope": { "type": "object" },
    "donorEligibility": { "type": "string" },
    "receiverEligibility": { "type": "string" },
    "rollbackReadiness": { "type": "string" },
    "sloProfile": { "type": "string" },
    "evidenceRefs": { "type": "array", "items": { "type": "string" } },
    "claimBoundary": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "remediations": { "type": "array", "items": { "type": "string" } }
  }
}
