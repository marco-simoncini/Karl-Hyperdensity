{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/auto-rollback-controller-v1.schema.json",
  "title": "KARL Hyperdensity Auto Rollback Controller v1",
  "type": "object",
  "required": [
    "autoRollbackControllerId",
    "autoRollbackControllerVersion",
    "releaseTrack",
    "controllerMode",
    "controllerState",
    "allowedNamespace",
    "productionRollbackAllowed",
    "productionMutationAllowed",
    "enforcementMode",
    "autonomousProductionApplyAllowed",
    "autonomousSandboxRollbackAllowed",
    "operatorKillSwitchRequired",
    "operatorKillSwitchState",
    "actionSlateId",
    "guardedAutoSandboxId",
    "policyPackId",
    "supportMatrixId",
    "evidenceBundleId",
    "liveResourceAuthorityId",
    "rollbackRequired",
    "verificationRequired",
    "auditRequired",
    "rollbackTriggerCount",
    "readyRollbackPlanCount",
    "blockedRollbackPlanCount",
    "rollbackPlans",
    "rollbackTriggers",
    "safetyGates",
    "blockers",
    "limitations",
    "claimBoundaries",
    "auditTrail"
  ],
  "properties": {
    "autoRollbackControllerId": { "const": "hyperdensity_auto_rollback_controller_v1" },
    "autoRollbackControllerVersion": { "const": "v1" },
    "releaseTrack": { "const": "technical_preview" },
    "controllerMode": { "const": "guarded_sandbox_rollback_readiness" },
    "controllerState": {
      "enum": [
        "auto_rollback_ready",
        "auto_rollback_readiness_only",
        "auto_rollback_blocked",
        "auto_rollback_unavailable"
      ]
    },
    "allowedNamespace": { "const": "karl-hyperdensity-evidence" },
    "productionRollbackAllowed": { "const": false },
    "productionMutationAllowed": { "const": false },
    "enforcementMode": { "const": "disabled" },
    "autonomousProductionApplyAllowed": { "const": false },
    "operatorKillSwitchRequired": { "const": true },
    "rollbackRequired": { "const": true },
    "verificationRequired": { "const": true },
    "auditRequired": { "const": true },
    "rollbackPlans": { "type": "array", "items": { "type": "object" } },
    "rollbackTriggers": { "type": "array", "minItems": 11, "items": { "type": "object" } },
    "safetyGates": { "type": "array", "minItems": 10, "items": { "type": "object" } },
    "claimBoundaries": { "type": "array", "minItems": 10, "items": { "type": "string" } }
  },
  "additionalProperties": true
}
