{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/realized-savings-ledger-v1.schema.json",
  "title": "KARL Hyperdensity Realized Savings Ledger v1",
  "type": "object",
  "required": ["milestone", "surfaceVersion", "ledgerId", "accountingWindow", "generatedAt", "sourceApplyGateRef", "movementRecordCount", "realizedValueTotal", "eligibleForFutureGuaranteeTotal", "excludedNonGuaranteedTotal", "estimatedOpportunityTotal", "estimatedValueCountedAsGuaranteed", "guaranteedSavingsAllowed", "guaranteedSavingsClaimed", "syntheticValueCountedAsProduction", "unitPriceCoverage", "sloPreservedCount", "rollbackReadyCount", "records", "claimPolicyRef", "sourceOfTruth", "safetyInvariants", "claimBoundaries"],
  "properties": {
    "milestone": { "const": "hyperdensity_realized_savings_ledger_v1" },
    "surfaceVersion": { "type": "string" },
    "ledgerId": { "type": "string" },
    "accountingWindow": { "type": "string" },
    "generatedAt": { "type": "string" },
    "sourceApplyGateRef": { "type": "string" },
    "movementRecordCount": { "type": "integer", "minimum": 0 },
    "realizedValueTotal": { "type": "number" },
    "eligibleForFutureGuaranteeTotal": { "type": "number" },
    "excludedNonGuaranteedTotal": { "type": "number" },
    "estimatedOpportunityTotal": { "type": "number" },
    "estimatedValueCountedAsGuaranteed": { "const": false },
    "guaranteedSavingsAllowed": { "const": false },
    "guaranteedSavingsClaimed": { "const": false },
    "syntheticValueCountedAsProduction": { "const": false },
    "unitPriceCoverage": { "type": "number" },
    "sloPreservedCount": { "type": "integer" },
    "rollbackReadyCount": { "type": "integer" },
    "records": { "type": "array" },
    "monthlyRollupRef": { "type": "string" },
    "claimPolicyRef": { "type": "string" },
    "sourceOfTruth": { "type": "object" },
    "safetyInvariants": { "type": "object" },
    "claimBoundaries": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } }
  }
}
