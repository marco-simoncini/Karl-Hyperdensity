{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marco-simoncini/Karl-Hyperdensity/schemas/fleet-equilibrium-onboarding-v1.schema.json",
  "title": "Fleet Equilibrium Onboarding v1",
  "type": "object",
  "required": [
    "contractId",
    "fleetMode",
    "fleetTotalShellCount",
    "fleetCompliantShellCount",
    "fleetReadyForEquilibriumCount",
    "fleetRemediableCount",
    "fleetBlockedCount",
    "fleetExcludedCount",
    "candidates"
  ],
  "properties": {
    "contractId": { "const": "hyperdensity_fleet_equilibrium_onboarding_v1" },
    "fleetMode": { "enum": ["recommendation_only"] },
    "fleetTotalShellCount": { "type": "integer", "minimum": 0 },
    "fleetCompliantShellCount": { "type": "integer", "minimum": 0 },
    "fleetReadyForEquilibriumCount": { "type": "integer", "minimum": 0 },
    "fleetRemediableCount": { "type": "integer", "minimum": 0 },
    "fleetBlockedCount": { "type": "integer", "minimum": 0 },
    "fleetExcludedCount": { "type": "integer", "minimum": 0 },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "objectRef",
          "shellKind",
          "candidateClass",
          "complianceState",
          "equilibriumEligibility",
          "evidenceState"
        ],
        "properties": {
          "objectRef": { "type": "string" },
          "shellKind": { "enum": ["vm_linux", "container_linux"] },
          "candidateClass": {
            "enum": [
              "reference",
              "compliant_member",
              "remediable",
              "blocked",
              "excluded"
            ]
          },
          "complianceState": { "type": "string" },
          "equilibriumEligibility": { "type": "boolean" },
          "evidenceState": { "type": "string" },
          "noEvidenceBorrowing": { "type": "boolean" },
          "blocker": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
